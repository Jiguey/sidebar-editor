{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Sidebar Editor",
  "identifier": "dev.sidebar.editor",
  "version": "0.1.0",
  "build": {
    "beforeDevCommand": "pnpm dev:web",
    "devUrl": "http://127.0.0.1:14200",
    "beforeBuildCommand": "pnpm build:skip-tests",
    "frontendDist": "../dist"
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "DeveloperTool",
    "shortDescription": "Local-first AI coding assistant",
    "longDescription": "A privacy-first desktop AI coding assistant. Run local models via Ollama or llama.cpp, or connect your own cloud API key. Your code never leaves your machine."
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Sidebar Editor",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["$DATA/**", "$HOME/**"]
      },
      "capabilities": ["default"]
    }
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
